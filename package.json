{
  "name": "vulcan-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @vulcan/web dev",
    "build": "pnpm --filter @vulcan/shared build && pnpm --filter @vulcan/web build",
    "start": "pnpm --filter @vulcan/web start -- --port 3001 --hostname 127.0.0.1",
    "lint": "pnpm --filter @vulcan/shared lint && pnpm --filter @vulcan/web lint",
    "seed": "pnpm --filter @vulcan/web seed",
    "adapter": "pnpm --filter @vulcan/web adapter",
    "test:smoke": "pnpm --filter @vulcan/web test:smoke",
    "db:generate": "pnpm --filter @vulcan/web db:generate",
    "db:migrate": "pnpm --filter @vulcan/web db:migrate"
  }
}
