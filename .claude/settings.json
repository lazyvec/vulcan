{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run build *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run seed)",
      "Bash(npm run adapter)",
      "Bash(npm run test:smoke)",
      "Bash(npx tsc *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsx *)",
      "Bash(npx prettier *)",
      "Bash(npx playwright *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm -f data/vulcan.db)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git checkout .)",
      "Bash(git checkout . *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval *)",
      "Bash(pm2 restart *)",
      "Bash(pm2 stop *)",
      "Bash(pm2 delete *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/credentials*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./.env.local)",
      "Edit(./secrets/**)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Vulcan Mission Control 세션 시작 ===' && echo '반드시 docs/PROGRESS.md를 먼저 읽고 현재 위치를 파악하세요.' && echo '다음 작업: docs/WORK_PLAN.md의 미완료 Phase 참조'",
            "timeout": 5,
            "statusMessage": "세션 연속성 가이드 로딩..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-dangerous.js",
            "timeout": 3,
            "statusMessage": "명령어 안전성 검사..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read file_path; if [ -n \"$file_path\" ] && echo \"$file_path\" | grep -qE '\\.(ts|tsx)$'; then echo \"[Hook] TypeScript 파일 수정됨: $file_path\"; fi; exit 0; }",
            "timeout": 5
          }
        ]
      }
    ]
  },

  "env": {},
  "language": "ko"
}
