VULCAN_API_PORT=8787
VULCAN_CORS_ORIGIN=*

# Phase 1+: PostgreSQL / Redis 연결
# Docker Compose 사용 시 (pnpm infra:up):
#   DATABASE_URL=postgresql://vulcan:vulcan_dev@127.0.0.1:5433/vulcan
#   REDIS_URL=redis://127.0.0.1:6380
DATABASE_URL=
REDIS_URL=

# 선택: DB/마이그레이션 경로 강제 지정
# VULCAN_DB_PATH=/home/linuxuser/projects/vulcan-mc/apps/web/data/vulcan.db
# VULCAN_DRIZZLE_PATH=/home/linuxuser/projects/vulcan-mc/apps/web/drizzle

# Phase 2 Batch2: OpenClaw Gateway RPC
# 필수(기본값 제공): Gateway 주소
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# 민감(선택): Gateway 인증 정보
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=

# 선택(기본값 제공): 연결/클라이언트 설정
VULCAN_GATEWAY_ROLE=operator
VULCAN_GATEWAY_SCOPES=operator.admin
VULCAN_GATEWAY_CLIENT_ID=gateway-client
VULCAN_GATEWAY_CLIENT_MODE=backend
VULCAN_GATEWAY_CLIENT_VERSION=
VULCAN_GATEWAY_PLATFORM=
VULCAN_GATEWAY_DEVICE_FAMILY=vulcan
VULCAN_GATEWAY_INSTANCE_ID=
VULCAN_GATEWAY_USER_AGENT=
VULCAN_GATEWAY_LOCALE=

# 선택(기본값 제공): 장치 ID/재연결 정책
VULCAN_GATEWAY_DEVICE_IDENTITY_PATH=.vulcan/gateway-device.json
VULCAN_GATEWAY_RECONNECT=1
VULCAN_GATEWAY_CHALLENGE_TIMEOUT_MS=2000
VULCAN_GATEWAY_CONNECT_TIMEOUT_MS=8000
VULCAN_GATEWAY_REQUEST_TIMEOUT_MS=10000
VULCAN_GATEWAY_RECONNECT_BASE_MS=1000
VULCAN_GATEWAY_RECONNECT_MAX_MS=30000

# Gateway 기반 이벤트 어댑터 (pnpm adapter)
VULCAN_INGEST_URL=http://127.0.0.1:8787/api/adapter/ingest
ADAPTER_POLL_MS=2000
ADAPTER_HEARTBEAT_MS=45000
ADAPTER_MAX_EVENTS_PER_MIN=40
ADAPTER_MAX_BATCH=12
ADAPTER_DRY_RUN=0

# Phase 7: Telegram 알림 (Herald Bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
