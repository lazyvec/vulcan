{
  "name": "@vulcan/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:gateway-rpc": "tsx --test src/gateway-rpc/client.test.ts",
    "test:gateway-event-adapter": "tsx --test src/gateway-rpc/event-adapter.test.ts",
    "adapter:gateway": "tsx scripts/adapter-openclaw-gateway.ts",
    "db:generate:pg": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate:pg": "drizzle-kit migrate --config drizzle.config.ts",
    "migrate:sqlite-to-pg": "tsx scripts/sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/node-ws": "^1.3.0",
    "@vulcan/shared": "workspace:*",
    "bullmq": "^5.58.5",
    "defuddle": "^0.10.0",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.10.4",
    "ioredis": "^5.8.1",
    "pg": "^8.16.3",
    "turndown": "^7.2.2",
    "better-sqlite3": "^12.6.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
