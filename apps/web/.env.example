# Vulcan runtime
NODE_ENV=production
PORT=3001

# Adapter -> Vulcan ingest
VULCAN_INGEST_URL=http://127.0.0.1:3001/api/adapter/ingest
OPENCLAW_LOG_DIR=/tmp/openclaw
OPENCLAW_LOG_FILE=
ADAPTER_POLL_MS=2000
ADAPTER_HEARTBEAT_MS=45000
ADAPTER_MAX_EVENTS_PER_MIN=20
ADAPTER_MAX_BATCH=5
ADAPTER_DRY_RUN=0

# Optional metadata
GIT_SHA=local
